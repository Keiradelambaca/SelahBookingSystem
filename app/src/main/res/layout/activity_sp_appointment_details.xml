<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- TOP APP BAR -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="Appointment Details"
        android:background="@color/white"
        android:titleTextColor="@color/black"
        app:navigationIcon="@drawable/ic_back"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- APPOINTMENT CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- CLIENT NAME TITLE -->
                    <TextView
                        android:id="@+id/tvClientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Client Name"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>

                    <!-- INSPO IMAGE THUMBNAIL -->
                    <ImageView
                        android:id="@+id/imgInspo"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="12dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/placeholder_banner"/>

                    <!-- SERVICE NAME -->
                    <TextView
                        android:id="@+id/tvServiceName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Acrylic Full Set"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:layout_marginTop="12dp"/>

                    <!-- DATE -->
                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mon 14 Apr"
                        android:textColor="@color/black"
                        android:layout_marginTop="6dp"/>

                    <!-- TIME -->
                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2:00 PM - 3:30 PM"
                        android:textColor="@color/black"
                        android:layout_marginTop="4dp"/>

                    <!-- START / END APPOINTMENT BUTTON -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartAppointment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Start Appointment"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/signaturePink"/>

                    <!-- RESCHEDULE BUTTON -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReschedule"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reschedule Appointment"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/textGrey"
                        android:textColor="@color/black"/>

                    <!-- CANCEL BUTTON -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCancel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cancel Appointment"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/invalidRed"
                        android:textColor="@color/white"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>